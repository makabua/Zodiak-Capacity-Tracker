# Server
PORT=3001
NODE_ENV=development

# Auth — generate the hash by running: npm run hash -- yourpassword
JWT_SECRET=change-this-to-a-long-random-string
DASHBOARD_PASSWORD_HASH=$2b$10$examplehashreplacethiswithrealone

# Email (SMTP)
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Zodiak Capacity Tracker <you@gmail.com>
